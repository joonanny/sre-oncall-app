# PostgreSQL
POSTGRES_DB=msp_oncall
POSTGRES_USER=msp_user
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://msp_user:change_me_strong_password@postgres:5432/msp_oncall

# Redis
REDIS_URL=redis://redis:6379

# Node
NODE_ENV=production
PORT=3000

# Authentik OIDC
AUTHENTIK_ISSUER=https://auth.your-domain.com/application/o/msp-oncall/
AUTHENTIK_CLIENT_ID=your_client_id
AUTHENTIK_CLIENT_SECRET=your_client_secret
AUTHENTIK_REDIRECT_URI=https://your-domain.com/callback

# JWT (Authentik이 발급한 토큰 검증용 public key URL)
JWKS_URI=https://auth.your-domain.com/application/o/msp-oncall/jwks/

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your_key_here

# AWS SES
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
SES_FROM_EMAIL=oncall@your-domain.com

# AWS S3 (백업용)
S3_BACKUP_BUCKET=your-backup-bucket-name

# Slack Bot
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0XXXXXXXXX

# Webhook 서명 검증 시크릿
WHATAP_WEBHOOK_SECRET=your_whatap_secret
DATADOG_WEBHOOK_SECRET=your_datadog_secret
